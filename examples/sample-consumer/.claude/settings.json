{
  "$schema": "https://json.schemastore.org/claude-code-settings.json",
  "_comment": "Sample post-install settings.json. Generated by SOMI installer — shows the shape after merging your existing settings (if any) with SOMI hooks and permissions.",
  "env": {
    "SOMI_ROOT": "${CLAUDE_PROJECT_DIR}/.claude/plugins/somi-ai",
    "SOMI_AUDIT_LOG": "${CLAUDE_PROJECT_DIR}/.claude/audit.log",
    "NODE_ENV": "development"
  },
  "permissions": {
    "allow": [
      "Read(**)",
      "Grep(**)",
      "Glob(**)",
      "Bash(npm test:*)",
      "Bash(npm run lint:*)",
      "Bash(npm run typecheck:*)",
      "Bash(git status:*)",
      "Bash(git diff:*)",
      "Bash(git log:*)"
    ],
    "deny": [
      "Read(./.env)",
      "Read(./.env.local)",
      "Read(./.env.production)",
      "Bash(curl * | sh)",
      "Bash(rm -rf /:*)",
      "Bash(git push --force:*)"
    ]
  },
  "hooks": {
    "PreToolUse": [
      {
        "matcher": "Bash",
        "hooks": [
          { "type": "command", "command": "${SOMI_ROOT}/hooks/pre-tool/block-dangerous-bash.sh" }
        ]
      },
      {
        "matcher": "Write|Edit",
        "hooks": [
          { "type": "command", "command": "${SOMI_ROOT}/hooks/pre-tool/block-secret-writes.sh" },
          { "type": "command", "command": "${SOMI_ROOT}/hooks/pre-tool/guard-protected-paths.sh" }
        ]
      }
    ],
    "PostToolUse": [
      {
        "matcher": "Write|Edit",
        "hooks": [
          { "type": "command", "command": "${SOMI_ROOT}/hooks/post-tool/lint-changed-files.sh" }
        ]
      },
      {
        "matcher": "*",
        "hooks": [
          { "type": "command", "command": "${SOMI_ROOT}/hooks/post-tool/audit-log.sh" }
        ]
      }
    ],
    "UserPromptSubmit": [
      {
        "hooks": [
          { "type": "command", "command": "${SOMI_ROOT}/hooks/user-prompt-submit/inject-workflow-context.sh" }
        ]
      }
    ],
    "Stop": [
      {
        "hooks": [
          { "type": "command", "command": "${SOMI_ROOT}/hooks/stop/enforce-handoff.sh" }
        ]
      }
    ]
  }
}
